{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YDOM",
  "scopeName": "source.ydom",
  "patterns": [
    {
      "include": "#tags"
    },
    {
      "include": "#attributesBlock"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "tags": {
      "match": "^\\s*([a-zA-Z0-9_-]+):",
      "captures": {
        "1": {
          "name": "entity.name.tag.ydom"
        }
      }
    },
    "attributesBlock": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.parameters.begin.ydom" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.parameters.end.ydom" }
      },
      "patterns": [
        {
          "match": "(@[a-zA-Z0-9_.-]+)",
          "name": "keyword.control.ydom"
        },
        {
          "match": "(:[a-zA-Z0-9_-]+)",
          "name": "entity.other.attribute-name.id.ydom"
        },
        {
          "match": "([a-zA-Z0-9_-]+)(?=\\s*=)",
          "name": "entity.other.attribute-name.ydom"
        },
        {
          "include": "#strings"
        }
      ]
    },
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.ydom"
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.ydom"
        },
        {
          "begin": "`",
          "end": "`",
          "name": "string.interpolated.ydom"
        }
      ]
    }
  }
}
