{
	"name": "ydom-vscode",
	"displayName": "YDOM for VS Code",
	"description": "Soporte oficial para lenguaje YDOM (YAML DOM).",
	"version": "1.0.2",
	"publisher": "joguel96",
	"license": "MIT",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.74.0"
	},
	"categories": [
		"Programming Languages"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/joguel96/ydom-extension"
	},
	"scripts": {
		"build": "vsce package"
	},
	"contributes": {
		"languages": [
			{
				"id": "ydom",
				"aliases": [
					"YDOM",
					"ydom"
				],
				"extensions": [
					".ydom"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "ydom",
				"scopeName": "source.ydom",
				"path": "./syntaxes/ydom.tmLanguage.json"
			}
		]
	}
}
